# ===========================================
# The Nest on Tennyson - Environment Variables
# Copy this file to .env and fill in your values
# ===========================================

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- Airbnb iCal ---
# Get this from Airbnb > Your Listing > Availability > Export Calendar
# It looks like: https://www.airbnb.co.nz/calendar/ical/XXXXXX.ics?s=XXXXXX
AIRBNB_ICAL_URL=https://www.airbnb.co.nz/calendar/ical/915503691247043740.ics?t=3ecc67113e6c4ead967bc464b493ced3

# --- Seam (Yale Lock Integration) ---
# Sign up at https://console.seam.co and connect your Yale lock
SEAM_API_KEY=seam_test_your_key_here
SEAM_DEVICE_ID=your_yale_lock_device_id

# --- Email (SMTP) ---
# You can use Gmail, SendGrid, or any SMTP provider
# For Gmail: enable "App passwords" in your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="The Nest on Tennyson <your_email@gmail.com>"

# --- General ---
SITE_URL=https://www.thenestontennyson.co.nz
PORT=3000

# --- Pricing ---
# All pricing is defined in server/index.js (and mirrored in index.html):
#   Base rates: 1-6 nights $250, 7-13 $230, 14-27 $210, 28+ $190
#   Cleaning: $150 (baked into nightly rate)
#   Extra guests: $15/night per guest above 2 (baked into nightly rate)
# Guest sees one all-inclusive nightly rate — no fee breakdown
